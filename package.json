{
  "name": "djot-grammars",
  "version": "1.0.0",
  "description": "Syntax highlighting grammars for the Djot markup language",
  "main": "index.js",
  "scripts": {
    "test": "node tests/grammar-test.js && node tests/parse-test.mjs",
    "test:install": "npm install --save-dev vscode-textmate vscode-oniguruma highlight.js prismjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/php-collective/djot-grammars.git"
  },
  "keywords": [
    "djot",
    "syntax-highlighting",
    "grammar",
    "textmate",
    "highlight.js",
    "prism",
    "shiki"
  ],
  "author": "php-collective",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/php-collective/djot-grammars/issues"
  },
  "homepage": "https://github.com/php-collective/djot-grammars#readme",
  "files": [
    "textmate/",
    "highlightjs/",
    "prismjs/",
    "tiptap/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./textmate/djot.tmLanguage.json": "./textmate/djot.tmLanguage.json",
    "./highlightjs/djot.js": "./highlightjs/djot.js",
    "./prismjs/djot.js": "./prismjs/djot.js",
    "./tiptap": "./tiptap/index.js",
    "./tiptap/*": "./tiptap/*"
  },
  "devDependencies": {
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-bullet-list": "^2.27.2",
    "@tiptap/extension-code-block": "^2.27.2",
    "@tiptap/extension-hard-break": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-list-item": "^2.27.2",
    "@tiptap/extension-subscript": "^2.27.2",
    "@tiptap/extension-superscript": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "happy-dom": "^20.10.6",
    "highlight.js": "^11.11.1",
    "prismjs": "^1.30.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
